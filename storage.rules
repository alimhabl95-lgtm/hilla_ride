rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /driver_applications/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /driver_applications/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /user_profiles/{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.auth.uid == userId
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /ride_chat/{rideId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
    }

    match /releases/{fileName} {
      allow read: if true;
      allow write: if false;
    }
  }
}
